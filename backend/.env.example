# ------------------------------------------------------------------------------
# Enterprise Knowledge Copilot — backend configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ------------------------------------------------------------------------------

# --- Application ---
APP_NAME="Enterprise Knowledge Copilot"
# One of: local | dev | staging | production
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# --- Logging ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_JSON=true emits structured JSON logs (use in prod); false = human console
LOG_JSON=false

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be overridden in production — the app refuses to start otherwise.
SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PostgreSQL (async DSN for the app) ---
DATABASE_URL=postgresql+asyncpg://ekc:ekc@localhost:5432/ekc
# Apply migrations on startup (disable when a deploy job runs them)
AUTO_MIGRATE=true

# --- Redis (cache, rate limiting, Celery broker/result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage ---
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=52428800

# --- RAG providers ---
# Defaults run fully local with zero API keys. Swap providers here as cloud
# adapters land (e.g. VECTOR_STORE_PROVIDER=qdrant, EMBEDDER_PROVIDER=openai).
PARSER_PROVIDER=local
EMBEDDER_PROVIDER=hashing
VECTOR_STORE_PROVIDER=memory
SPARSE_PROVIDER=local-bm25
RERANKER_PROVIDER=lexical
LLM_PROVIDER=extractive
EMBEDDING_DIMENSION=384

# --- OCR for scanned pages/images (CPU tier; needs `pip install .[ocr]`) ---
# rapidocr | none — a GPU VLM-OCR tier plugs into the same port later
OCR_PROVIDER=rapidocr
OCR_RENDER_SCALE=3.0
OCR_MIN_LINE_CONFIDENCE=0.5

# --- Qdrant (when VECTOR_STORE_PROVIDER=qdrant) ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=ekc_chunks

# --- LLM providers (when LLM_PROVIDER=anthropic | openai | ollama) ---
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
# Used when EMBEDDER_PROVIDER=openai (dimension follows EMBEDDING_DIMENSION)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Ollama/vLLM/LM Studio (OpenAI-compatible local endpoint)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# --- Chunking defaults (profiles override per domain) ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- Ingestion mode: true = inline in request, false = Celery queue ---
INGESTION_EAGER=true

# --- Local ONNX inference (EMBEDDER_PROVIDER=fastembed / RERANKER_PROVIDER=onnx) ---
# Requires the [local] extra. Real semantic search on CPU, zero external calls
# after the one-time model download.
#FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
#RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
# Where downloaded model weights live (unset = fastembed default cache)
#MODEL_CACHE_DIR=./models

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
# memory = per replica (default); redis = shared sliding window across replicas
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_QUERY_PER_MINUTE=120

# --- OIDC single sign-on (optional; enabled when all four are set) ---
# Works with Microsoft Entra, Google Workspace, Okta, Keycloak, ...
#OIDC_ISSUER=https://accounts.google.com
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_REDIRECT_URL=http://localhost:8000/api/v1/auth/oidc/callback
#OIDC_PROVIDER_NAME=Google
#OIDC_SCOPES=openid email profile

# --- Click-to-connect cloud connectors (optional) ---
# PUBLIC_BASE_URL is this deployment's address as browsers see it — OAuth
# providers redirect back to it. Required for Google Drive and Notion.
#PUBLIC_BASE_URL=http://localhost:8000

# Google Drive: OAuth client (Web application) with the drive.readonly scope.
# Authorized redirect URI: {PUBLIC_BASE_URL}/api/v1/connectors/gdrive/callback
#GDRIVE_CLIENT_ID=
#GDRIVE_CLIENT_SECRET=

# Notion: public integration (notion.so/my-integrations).
# Redirect URI: {PUBLIC_BASE_URL}/api/v1/connectors/notion/callback
#NOTION_CLIENT_ID=
#NOTION_CLIENT_SECRET=

# Confluence needs no env vars — admins paste site URL, email, and an
# Atlassian API token in the UI; the token is stored encrypted.

# --- Frontend ---
# Directory of the built web app (Next.js static export). Unset = repo-relative
# frontend/out when present; otherwise the single-file console is served.
#FRONTEND_DIST=
